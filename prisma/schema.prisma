generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  SUPER_MASTER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nickname     String?
  role         Role     @default(USER)
  suspended    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
